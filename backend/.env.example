# =============================================
# Intent-Based Autonomous Agent Infrastructure
# Backend Environment Configuration
# =============================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Firebase Admin SDK ---
# Option 1: Path to service account key file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option 2: Individual env vars (use one approach, not both)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Gemini API (for LangChain Orchestrator) ---
GOOGLE_API_KEY=your-gemini-api-key-here

# --- Web3 / RPC ---
# Get a free key from https://www.alchemy.com or https://infura.io
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your-alchemy-key

# --- CoinGecko (Price Feed) ---
# Free tier works for this. Get key at https://www.coingecko.com/api
COINGECKO_API_KEY=your-coingecko-api-key

# --- Execution Engine ---
# How often the background worker polls Firestore (in milliseconds)
EXECUTION_INTERVAL_MS=60000
